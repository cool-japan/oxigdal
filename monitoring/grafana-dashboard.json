{
  "dashboard": {
    "title": "OxiGDAL Server Dashboard",
    "tags": ["oxigdal", "geospatial", "monitoring"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Request Rate",
        "type": "graph",
        "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(http_requests_total{job=\"oxigdal-server\"}[5m])",
            "legendFormat": "{{instance}} - {{method}} {{path}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "reqps", "label": "Requests/sec"},
          {"format": "short"}
        ]
      },
      {
        "id": 2,
        "title": "Request Duration (p95)",
        "type": "graph",
        "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"oxigdal-server\"}[5m]))",
            "legendFormat": "{{instance}} - p95",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=\"oxigdal-server\"}[5m]))",
            "legendFormat": "{{instance}} - p99",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "s", "label": "Duration"},
          {"format": "short"}
        ]
      },
      {
        "id": 3,
        "title": "Error Rate",
        "type": "graph",
        "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(http_requests_total{job=\"oxigdal-server\",status=~\"5..\"}[5m])",
            "legendFormat": "{{instance}} - 5xx errors",
            "refId": "A"
          },
          {
            "expr": "rate(http_requests_total{job=\"oxigdal-server\",status=~\"4..\"}[5m])",
            "legendFormat": "{{instance}} - 4xx errors",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "reqps", "label": "Errors/sec"},
          {"format": "short"}
        ],
        "alert": {
          "conditions": [
            {
              "evaluator": {"params": [0.1], "type": "gt"},
              "operator": {"type": "and"},
              "query": {"params": ["A", "5m", "now"]},
              "reducer": {"params": [], "type": "avg"},
              "type": "query"
            }
          ],
          "executionErrorState": "alerting",
          "frequency": "60s",
          "handler": 1,
          "name": "High Error Rate",
          "noDataState": "no_data",
          "notifications": []
        }
      },
      {
        "id": 4,
        "title": "CPU Usage",
        "type": "graph",
        "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(process_cpu_seconds_total{job=\"oxigdal-server\"}[5m])",
            "legendFormat": "{{instance}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "percentunit", "label": "CPU", "max": 1, "min": 0},
          {"format": "short"}
        ]
      },
      {
        "id": 5,
        "title": "Memory Usage",
        "type": "graph",
        "gridPos": {"x": 0, "y": 16, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "process_resident_memory_bytes{job=\"oxigdal-server\"}",
            "legendFormat": "{{instance}} - RSS",
            "refId": "A"
          },
          {
            "expr": "process_virtual_memory_bytes{job=\"oxigdal-server\"}",
            "legendFormat": "{{instance}} - Virtual",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "bytes", "label": "Memory"},
          {"format": "short"}
        ]
      },
      {
        "id": 6,
        "title": "Active Connections",
        "type": "graph",
        "gridPos": {"x": 12, "y": 16, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "http_connections_active{job=\"oxigdal-server\"}",
            "legendFormat": "{{instance}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "Connections"},
          {"format": "short"}
        ]
      },
      {
        "id": 7,
        "title": "Cache Hit Rate",
        "type": "graph",
        "gridPos": {"x": 0, "y": 24, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(cache_hits_total{job=\"oxigdal-server\"}[5m]) / rate(cache_requests_total{job=\"oxigdal-server\"}[5m])",
            "legendFormat": "{{instance}} - Hit Rate",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "percentunit", "label": "Hit Rate", "max": 1, "min": 0},
          {"format": "short"}
        ]
      },
      {
        "id": 8,
        "title": "Tile Generation Rate",
        "type": "graph",
        "gridPos": {"x": 12, "y": 24, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(tile_generation_total{job=\"oxigdal-server\"}[5m])",
            "legendFormat": "{{instance}} - Success",
            "refId": "A"
          },
          {
            "expr": "rate(tile_generation_failures_total{job=\"oxigdal-server\"}[5m])",
            "legendFormat": "{{instance}} - Failures",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "ops", "label": "Tiles/sec"},
          {"format": "short"}
        ]
      },
      {
        "id": 9,
        "title": "Database Connection Pool",
        "type": "graph",
        "gridPos": {"x": 0, "y": 32, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "pg_stat_database_numbackends{datname=\"oxigdal\"}",
            "legendFormat": "Active Connections",
            "refId": "A"
          },
          {
            "expr": "pg_settings_max_connections",
            "legendFormat": "Max Connections",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "Connections"},
          {"format": "short"}
        ]
      },
      {
        "id": 10,
        "title": "Redis Memory Usage",
        "type": "graph",
        "gridPos": {"x": 12, "y": 32, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "redis_memory_used_bytes",
            "legendFormat": "Used Memory",
            "refId": "A"
          },
          {
            "expr": "redis_memory_max_bytes",
            "legendFormat": "Max Memory",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "bytes", "label": "Memory"},
          {"format": "short"}
        ]
      },
      {
        "id": 11,
        "title": "Request Methods Distribution",
        "type": "piechart",
        "gridPos": {"x": 0, "y": 40, "w": 6, "h": 8},
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{job=\"oxigdal-server\"}[5m])) by (method)",
            "legendFormat": "{{method}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 12,
        "title": "Response Status Codes",
        "type": "piechart",
        "gridPos": {"x": 6, "y": 40, "w": 6, "h": 8},
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{job=\"oxigdal-server\"}[5m])) by (status)",
            "legendFormat": "{{status}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 13,
        "title": "Top Requested Paths",
        "type": "table",
        "gridPos": {"x": 12, "y": 40, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "topk(10, sum(rate(http_requests_total{job=\"oxigdal-server\"}[5m])) by (path))",
            "format": "table",
            "refId": "A"
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {"Time": true},
              "indexByName": {"path": 0, "Value": 1},
              "renameByName": {"Value": "Requests/sec", "path": "Path"}
            }
          }
        ]
      },
      {
        "id": 14,
        "title": "System Load Average",
        "type": "stat",
        "gridPos": {"x": 0, "y": 48, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "node_load5",
            "refId": "A"
          }
        ],
        "options": {
          "graphMode": "area",
          "orientation": "auto",
          "textMode": "value_and_name"
        }
      },
      {
        "id": 15,
        "title": "Disk Usage",
        "type": "stat",
        "gridPos": {"x": 6, "y": 48, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "100 - ((node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}) * 100)",
            "refId": "A"
          }
        ],
        "options": {
          "graphMode": "area",
          "orientation": "auto",
          "textMode": "value_and_name",
          "unit": "percent"
        }
      },
      {
        "id": 16,
        "title": "Uptime",
        "type": "stat",
        "gridPos": {"x": 12, "y": 48, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "time() - process_start_time_seconds{job=\"oxigdal-server\"}",
            "refId": "A"
          }
        ],
        "options": {
          "graphMode": "none",
          "orientation": "auto",
          "textMode": "value_and_name",
          "unit": "s"
        }
      },
      {
        "id": 17,
        "title": "Version Info",
        "type": "stat",
        "gridPos": {"x": 18, "y": 48, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "oxigdal_version_info",
            "refId": "A"
          }
        ],
        "options": {
          "graphMode": "none",
          "orientation": "auto",
          "textMode": "name"
        }
      }
    ],
    "templating": {
      "list": [
        {
          "name": "datasource",
          "type": "datasource",
          "query": "prometheus"
        },
        {
          "name": "instance",
          "type": "query",
          "datasource": "$datasource",
          "query": "label_values(http_requests_total{job=\"oxigdal-server\"}, instance)",
          "refresh": 1,
          "multi": true,
          "includeAll": true
        }
      ]
    },
    "time": {
      "from": "now-6h",
      "to": "now"
    }
  }
}
