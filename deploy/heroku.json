{
  "name": "oxigdal-server",
  "description": "OxiGDAL Geospatial Server - Pure Rust GDAL alternative",
  "repository": "https://github.com/cool-japan/oxigdal",
  "logo": "https://github.com/cool-japan/oxigdal/raw/main/docs/logo.png",
  "keywords": [
    "geospatial",
    "gdal",
    "rust",
    "gis",
    "wms",
    "wmts",
    "tiles"
  ],
  "stack": "container",
  "formation": {
    "web": {
      "quantity": 2,
      "size": "standard-2x"
    }
  },
  "addons": [
    {
      "plan": "heroku-postgresql:standard-0",
      "as": "DATABASE"
    },
    {
      "plan": "heroku-redis:premium-0",
      "as": "REDIS"
    }
  ],
  "buildpacks": [],
  "env": {
    "RUST_LOG": {
      "description": "Rust logging level",
      "value": "info",
      "required": false
    },
    "RUST_BACKTRACE": {
      "description": "Enable Rust backtraces",
      "value": "1",
      "required": false
    },
    "OXIGDAL_HOST": {
      "description": "Server host address",
      "value": "0.0.0.0",
      "required": true
    },
    "OXIGDAL_PORT": {
      "description": "Server port",
      "generator": "port",
      "required": true
    },
    "OXIGDAL_DATA_DIR": {
      "description": "Data directory path",
      "value": "/app/data",
      "required": false
    },
    "OXIGDAL_CACHE_DIR": {
      "description": "Cache directory path",
      "value": "/app/cache",
      "required": false
    },
    "POSTGRES_HOST": {
      "description": "PostgreSQL host (auto-configured via DATABASE_URL)",
      "required": false
    },
    "POSTGRES_PORT": {
      "description": "PostgreSQL port",
      "value": "5432",
      "required": false
    },
    "POSTGRES_DB": {
      "description": "PostgreSQL database name",
      "required": false
    },
    "POSTGRES_USER": {
      "description": "PostgreSQL user",
      "required": false
    },
    "POSTGRES_PASSWORD": {
      "description": "PostgreSQL password",
      "required": false
    }
  },
  "scripts": {
    "postdeploy": "echo 'OxiGDAL deployed successfully!'"
  },
  "image": "heroku/heroku:22"
}
