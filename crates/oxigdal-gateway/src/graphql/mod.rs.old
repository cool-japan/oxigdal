//! GraphQL API module for OxiGDAL Gateway.
//!
//! Provides a comprehensive GraphQL server with queries, mutations, subscriptions,
//! DataLoader for N+1 problem resolution, query complexity analysis, and depth limiting.
//!
//! # Features
//!
//! - **Schema Definitions**: Comprehensive geospatial data types (raster, vector, CRS)
//! - **Query Resolvers**: Fetch datasets, layers, features, and raster tiles
//! - **Mutation Resolvers**: Create, update, delete operations with validation
//! - **Subscriptions**: Real-time updates for data changes and processing events
//! - **DataLoader**: Batch loading to prevent N+1 query problems
//! - **Security**: Query complexity and depth limiting
//!
//! # Example
//!
//! ```rust,no_run
//! use oxigdal_gateway::graphql::{GraphQLServer, GraphQLConfig};
//!
//! #[tokio::main]
//! async fn main() {
//!     let config = GraphQLConfig::default();
//!     let server = GraphQLServer::new(config);
//!
//!     // Execute a query
//!     let query = r#"
//!         query {
//!             dataset(id: "dem_world") {
//!                 id
//!                 name
//!                 bounds { minX minY maxX maxY }
//!             }
//!         }
//!     "#;
//!
//!     let context = GraphQLContext {
//!         user_id: Some("user123".to_string()),
//!         request_id: "req_001".to_string(),
//!     };
//!
//!     let result = server.execute(query, None, context).await;
//! }
//! ```

pub mod mutations;
pub mod queries;
pub mod resolvers;
pub mod schema;
pub mod subscriptions;

use crate::error::{GatewayError, Result};
use async_graphql::{Context, Enum, ID, InputObject, Object, Schema, SimpleObject, Subscription};
use std::collections::HashMap;
use std::sync::Arc;

// =============================================================================
// Configuration
// =============================================================================

/// GraphQL server configuration.
#[derive(Debug, Clone)]
pub struct GraphQLConfig {
    /// Enable introspection
    pub enable_introspection: bool,
    /// Maximum query depth
    pub max_depth: usize,
    /// Maximum query complexity
    pub max_complexity: usize,
    /// Enable subscriptions
    pub enable_subscriptions: bool,
    /// Enable DataLoader
    pub enable_dataloader: bool,
    /// Enable tracing
    pub enable_tracing: bool,
    /// Cache TTL in seconds
    pub cache_ttl_secs: u64,
    /// Maximum page size for pagination
    pub max_page_size: i32,
}

impl Default for GraphQLConfig {
    fn default() -> Self {
        Self {
            enable_introspection: true,
            max_depth: 10,
            max_complexity: 1000,
            enable_subscriptions: true,
            enable_dataloader: true,
            enable_tracing: false,
            cache_ttl_secs: 300,
            max_page_size: 100,
        }
    }
}

/// GraphQL context data passed to resolvers.
#[derive(Clone)]
pub struct GraphQLContext {
    /// User ID if authenticated
    pub user_id: Option<String>,
    /// Request ID for tracing
    pub request_id: String,
}

// =============================================================================
// Enums
