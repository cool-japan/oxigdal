    /// Mesh layer (3D surfaces)
    Mesh,
    /// Time series layer
    TimeSeries,
}

/// Geometry type enumeration.
#[derive(Debug, Clone, Copy, PartialEq, Eq, Enum)]
pub enum GeometryType {
    /// Point geometry
